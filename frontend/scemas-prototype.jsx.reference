// ─── Sparkline Component ───
const Sparkline = ({ data, color = T.accent, width = 120, height = 32 }) => {
  const min = Math.min(...data);
  const max = Math.max(...data);
  const range = max - min || 1;
  const points = data.map((v, i) =>
    `${(i / (data.length - 1)) * width},${height - ((v - min) / range) * (height - 4) - 2}`
  ).join(" ");
  return (
    <svg width={width} height={height} style={{ display: "block" }}>
      <polyline points={points} fill="none" stroke={color} strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round" />
    </svg>
  );
};

// ─── Gauge Component ───
const Gauge = ({ value, max, label, unit, color = T.accent }) => {
  const pct = Math.min(value / max, 1);
  return (
    <div style={{ textAlign: "center" }}>
      <svg width="100" height="80" viewBox="0 0 100 80">
        <path d="M 10 70 A 40 40 0 1 1 90 70" fill="none" stroke={T.border} strokeWidth="6" strokeLinecap="round" />
        <path d="M 10 70 A 40 40 0 1 1 90 70" fill="none" stroke={color} strokeWidth="6" strokeLinecap="round"
          strokeDasharray={`${pct * 200} 300`} />
        <text x="50" y="50" textAnchor="middle" fill={T.text} fontSize="18" fontWeight="700" fontFamily={T.font}>{value}</text>
        <text x="50" y="64" textAnchor="middle" fill={T.textMuted} fontSize="9" fontFamily={T.font}>{unit}</text>
      </svg>
      <div style={{ fontSize: "11px", color: T.textSecondary, marginTop: "4px" }}>{label}</div>
    </div>
  );
};

