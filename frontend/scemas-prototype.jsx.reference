// ─── Navigation ───
const Navbar = ({ page, setPage, role, onLogout }) => {
  const links = role === "admin"
    ? [
        { key: "dashboard", label: "Dashboard" },
        { key: "alerts", label: "Alerts" },
        { key: "alert-rules", label: "Rules" },
        { key: "sensors", label: "Sensors" },
        { key: "rankings", label: "Rankings" },
        { key: "accounts", label: "Accounts" },
        { key: "audit", label: "Audit Log" },
      ]
    : role === "operator"
    ? [
        { key: "dashboard", label: "Dashboard" },
        { key: "alerts", label: "Alerts" },
        { key: "sensors", label: "Sensors" },
        { key: "rankings", label: "Rankings" },
        { key: "account-edit", label: "Account" },
      ]
    : [
        { key: "public", label: "Overview" },
        { key: "rankings", label: "Rankings" },
        { key: "api-docs", label: "API" },
      ];

  return (
    <nav style={styles.nav}>
      <div style={styles.navLeft}>
        <div style={styles.logo} onClick={() => setPage(role === "public" ? "public" : "dashboard")}>
          <Icon name="logo" size={20} />
          <span>SCEMAS</span>
          {role !== "public" && (
            <span style={{ ...styles.badge(role === "admin" ? "info" : "default"), marginLeft: "4px" }}>
              {role}
            </span>
          )}
        </div>
        <div style={{ display: "flex", gap: "16px", marginLeft: "16px" }}>
          {links.map(l => (
            <span key={l.key} style={styles.navLink(page === l.key)} onClick={() => setPage(l.key)}>
              {l.label}
            </span>
          ))}
        </div>
      </div>
      <div style={{ display: "flex", alignItems: "center", gap: "12px" }}>
        {role !== "public" && (
          <>
            <div style={{ position: "relative", cursor: "pointer" }} onClick={() => setPage("alerts")}>
              <Icon name="bell" size={16} color={T.textSecondary} />
              <div style={{
                position: "absolute", top: -4, right: -4, width: 8, height: 8,
                borderRadius: "50%", background: T.error,
              }} />
            </div>
            <span style={{ fontSize: "13px", color: T.textSecondary, cursor: "pointer" }} onClick={() => setPage("account-edit")}>
              <Icon name="user" size={16} />
            </span>
          </>
        )}
        <button style={styles.btn("default")} onClick={onLogout}>
          <Icon name="logout" size={14} />
          {role === "public" ? "Sign In" : "Logout"}
        </button>
      </div>
    </nav>
  );
};

// ─── Page: Login ───
const LoginPage = ({ onLogin }) => {
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [error, setError] = useState("");
  const [loading, setLoading] = useState(false);

  const handleSubmit = () => {
    setLoading(true);
    setError("");
    setTimeout(() => {
      if (email.includes("admin")) onLogin("admin");
      else if (email && password) onLogin("operator");
      else { setError("Invalid email or password. Please try again."); setLoading(false); }
    }, 800);
  };

  return (
    <div style={{ ...styles.page, display: "flex", alignItems: "center", justifyContent: "center" }}>
      <div style={{ width: "360px" }}>
        <div style={{ textAlign: "center", marginBottom: "40px" }}>
          <div style={{ ...styles.logo, justifyContent: "center", fontSize: "20px", marginBottom: "8px" }}>
            <Icon name="logo" size={28} />
            SCEMAS
          </div>
          <p style={{ color: T.textSecondary, fontSize: "14px" }}>Smart City Environmental Monitoring</p>
        </div>

        <div style={{ ...styles.card, padding: "32px" }}>
          <h2 style={{ ...styles.h2, marginBottom: "24px" }}>Sign in</h2>

          {error && (
            <div style={{
              padding: "10px 14px", borderRadius: T.radius, background: T.errorBg,
              border: `1px solid rgba(238,0,0,0.15)`, marginBottom: "16px",
              fontSize: "13px", color: T.error, display: "flex", alignItems: "center", gap: "8px"
            }}>
              <Icon name="alert" size={14} color={T.error} /> {error}
            </div>
          )}

          <div style={{ marginBottom: "16px" }}>
            <label style={styles.label}>Email</label>
            <input style={styles.input} type="email" placeholder="you@scemas.ca" value={email} onChange={e => setEmail(e.target.value)} onKeyDown={e => e.key === "Enter" && handleSubmit()} />
          </div>

          <div style={{ marginBottom: "24px" }}>
            <label style={styles.label}>Password</label>
            <input style={styles.input} type="password" placeholder="••••••••" value={password} onChange={e => setPassword(e.target.value)} onKeyDown={e => e.key === "Enter" && handleSubmit()} />
          </div>

          <button style={{ ...styles.btn("primary"), width: "100%", justifyContent: "center", padding: "10px", opacity: loading ? 0.7 : 1 }} onClick={handleSubmit} disabled={loading}>
            {loading ? "Signing in..." : "Continue"}
          </button>

          <div style={{ textAlign: "center", marginTop: "16px" }}>
            <span style={{ fontSize: "13px", color: T.textSecondary }}>
              Don't have an account? <span style={{ color: T.accent, cursor: "pointer" }}>Create one</span>
            </span>
          </div>
        </div>

        <div style={{ textAlign: "center", marginTop: "24px" }}>
          <span style={{ fontSize: "12px", color: T.textMuted, cursor: "pointer" }} onClick={() => onLogin("public")}>
            Continue as public user →
          </span>
        </div>
      </div>
    </div>
  );
};

// ─── Page: Create Account ───
const CreateAccountPage = ({ setPage }) => (
  <div style={{ ...styles.page, display: "flex", alignItems: "center", justifyContent: "center" }}>
    <div style={{ width: "360px" }}>
      <div style={{ textAlign: "center", marginBottom: "40px" }}>
        <div style={{ ...styles.logo, justifyContent: "center", fontSize: "20px", marginBottom: "8px" }}>
          <Icon name="logo" size={28} /> SCEMAS
        </div>
      </div>
      <div style={{ ...styles.card, padding: "32px" }}>
        <h2 style={{ ...styles.h2, marginBottom: "24px" }}>Create account</h2>
        <div style={{ marginBottom: "16px" }}><label style={styles.label}>Email</label><input style={styles.input} type="email" placeholder="you@scemas.ca" /></div>
        <div style={{ marginBottom: "16px" }}><label style={styles.label}>Password</label><input style={styles.input} type="password" placeholder="Minimum 8 characters" /></div>
        <div style={{ marginBottom: "24px" }}><label style={styles.label}>Confirm Password</label><input style={styles.input} type="password" placeholder="Repeat password" /></div>
        <button style={{ ...styles.btn("primary"), width: "100%", justifyContent: "center", padding: "10px" }}>Create Account</button>
        <div style={{ textAlign: "center", marginTop: "16px" }}>
          <span style={{ fontSize: "13px", color: T.textSecondary }}>Already have an account? <span style={{ color: T.accent, cursor: "pointer" }} onClick={() => setPage("login")}>Sign in</span></span>
        </div>
      </div>
    </div>
  </div>
);

// ─── Page: Public View ───
const PublicPage = () => (
  <div style={styles.container}>
    <div style={{ padding: "48px 0 24px" }}>
      <h1 style={styles.h1}>Environmental Overview</h1>
      <p style={{ color: T.textSecondary, marginTop: "8px", fontSize: "15px" }}>Real-time environmental conditions across monitored city zones.</p>
    </div>
    <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: "12px", marginBottom: "32px" }}>
      {[
        { icon: "wind", label: "Avg. AQI", value: "47", sub: "Moderate", color: T.warning, data: MOCK.sparkData.aqi },
        { icon: "thermometer", label: "Avg. Temp", value: "18°C", sub: "Normal", color: T.accent, data: MOCK.sparkData.temp },
        { icon: "droplet", label: "Avg. Humidity", value: "62%", sub: "Normal", color: T.accent, data: MOCK.sparkData.humidity },
        { icon: "volume", label: "Avg. Noise", value: "61 dB", sub: "Moderate", color: T.warning, data: MOCK.sparkData.noise },
      ].map((m, i) => (
        <div key={i} style={styles.card}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
            <div>
              <div style={{ display: "flex", alignItems: "center", gap: "6px", color: T.textSecondary, fontSize: "12px", marginBottom: "8px" }}><Icon name={m.icon} size={14} /> {m.label}</div>
              <div style={{ fontSize: "28px", fontWeight: 700, letterSpacing: "-0.03em" }}>{m.value}</div>
              <div style={{ fontSize: "12px", color: m.color, marginTop: "2px" }}>{m.sub}</div>
            </div>
            <Sparkline data={m.data} color={m.color} width={80} height={28} />
          </div>
        </div>
      ))}
    </div>
    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "16px", marginBottom: "32px" }}>
      <div style={{ ...styles.card, minHeight: "320px", display: "flex", flexDirection: "column" }}>
        <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Sensor Map</h3>
        <div style={{ flex: 1, borderRadius: T.radius, background: "#0d1117", border: `1px solid ${T.border}`, display: "flex", alignItems: "center", justifyContent: "center", position: "relative", overflow: "hidden" }}>
          <svg width="100%" height="100%" viewBox="0 0 400 280" style={{ position: "absolute" }}>
            {Array.from({ length: 20 }, (_, i) => (<line key={`h${i}`} x1="0" y1={i * 14} x2="400" y2={i * 14} stroke={T.border} strokeWidth="0.5" />))}
            {Array.from({ length: 28 }, (_, i) => (<line key={`v${i}`} x1={i * 14} y1="0" x2={i * 14} y2="280" stroke={T.border} strokeWidth="0.5" />))}
            {[{ x: 200, y: 80, c: T.success }, { x: 120, y: 140, c: T.success }, { x: 310, y: 110, c: T.warning }, { x: 80, y: 200, c: T.success }, { x: 260, y: 180, c: T.error }, { x: 340, y: 200, c: T.success }, { x: 160, y: 60, c: T.success }, { x: 300, y: 230, c: T.textMuted }].map((s, i) => (
              <g key={i}><circle cx={s.x} cy={s.y} r="12" fill={s.c} opacity="0.15" /><circle cx={s.x} cy={s.y} r="4" fill={s.c} /></g>
            ))}
          </svg>
          <div style={{ position: "absolute", bottom: "12px", left: "12px", display: "flex", gap: "12px", fontSize: "10px" }}>
            {[{ c: T.success, l: "Good" }, { c: T.warning, l: "Warning" }, { c: T.error, l: "Alert" }, { c: T.textMuted, l: "Offline" }].map((item, i) => (
              <span key={i} style={{ display: "flex", alignItems: "center", gap: "4px", color: T.textSecondary }}><span style={{ width: 6, height: 6, borderRadius: "50%", background: item.c }} /> {item.l}</span>
            ))}
          </div>
        </div>
      </div>
      <div style={styles.card}>
        <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Zone Conditions</h3>
        <table style={styles.table}>
          <thead><tr><th style={styles.th}>Zone</th><th style={styles.th}>AQI</th><th style={styles.th}>Temp</th><th style={styles.th}>Noise</th><th style={styles.th}>Status</th></tr></thead>
          <tbody>
            {MOCK.zones.map(z => (
              <tr key={z.id}>
                <td style={{ ...styles.td, fontWeight: 500 }}>{z.name}</td><td style={styles.td}>{z.aqi}</td><td style={styles.td}>{z.temp}°C</td><td style={styles.td}>{z.noise} dB</td>
                <td style={styles.td}><span style={styles.badge(z.status === "good" ? "success" : z.status === "alert" ? "error" : "warning")}>{z.status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <div style={{ ...styles.card, marginBottom: "48px" }}>
      <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Active Alerts</h3>
      <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
        {MOCK.alerts.filter(a => a.status === "active").map(a => (
          <div key={a.id} style={{ padding: "12px 16px", borderRadius: T.radius, background: a.severity === "critical" ? T.errorBg : T.warningBg, border: `1px solid ${a.severity === "critical" ? "rgba(238,0,0,0.15)" : "rgba(245,166,35,0.15)"}`, display: "flex", justifyContent: "space-between", alignItems: "center" }}>
            <div style={{ display: "flex", alignItems: "center", gap: "12px" }}>
              <Icon name="alert" size={16} color={a.severity === "critical" ? T.error : T.warning} />
              <div><div style={{ fontWeight: 500, fontSize: "13px" }}>{a.type} — {a.zone}</div><div style={{ fontSize: "12px", color: T.textSecondary }}>{a.value} · {a.rule}</div></div>
            </div>
            <span style={{ fontSize: "12px", color: T.textMuted }}>{a.time}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
);

// ─── Page: Dashboard ───
const DashboardPage = ({ role, setPage }) => (
  <div style={styles.container}>
    <div style={{ padding: "32px 0 24px", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
      <div><h1 style={styles.h1}>Dashboard</h1><p style={{ color: T.textSecondary, marginTop: "4px" }}>System overview and real-time monitoring</p></div>
      <div style={{ display: "flex", gap: "8px" }}>
        <button style={styles.btn()} onClick={() => setPage("sensors")}><Icon name="database" size={14} /> Sensors</button>
        {role === "admin" && <button style={styles.btn("primary")} onClick={() => setPage("alert-rules")}><Icon name="plus" size={14} /> New Rule</button>}
      </div>
    </div>
    <div style={{ display: "grid", gridTemplateColumns: "repeat(5, 1fr)", gap: "12px", marginBottom: "24px" }}>
      {[{ label: "Active Alerts", value: "2", badge: "error" }, { label: "Sensors Online", value: "5/6", badge: "success" }, { label: "Zones Monitored", value: "6", badge: "info" }, { label: "Avg. AQI", value: "47", badge: "warning" }, { label: "Uptime", value: "99.8%", badge: "success" }].map((s, i) => (
        <div key={i} style={styles.card}>
          <div style={{ fontSize: "12px", color: T.textSecondary, marginBottom: "6px" }}>{s.label}</div>
          <div style={{ display: "flex", alignItems: "center", gap: "8px" }}><span style={{ fontSize: "24px", fontWeight: 700, letterSpacing: "-0.03em" }}>{s.value}</span><span style={styles.badge(s.badge)}>●</span></div>
        </div>
      ))}
    </div>
    <div style={{ ...styles.card, marginBottom: "16px" }}>
      <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Current Readings — Downtown Core</h3>
      <div style={{ display: "flex", justifyContent: "space-around", padding: "8px 0" }}>
        <Gauge value={42} max={200} label="Air Quality" unit="AQI" color={T.success} />
        <Gauge value={18} max={45} label="Temperature" unit="°C" color={T.accent} />
        <Gauge value={62} max={100} label="Humidity" unit="%" color={T.accent} />
        <Gauge value={68} max={120} label="Noise Level" unit="dB" color={T.warning} />
      </div>
    </div>
    <div style={{ display: "grid", gridTemplateColumns: "1.4fr 1fr", gap: "16px", marginBottom: "24px" }}>
      <div style={{ ...styles.card, minHeight: "280px" }}>
        <h3 style={{ ...styles.h3, marginBottom: "12px" }}>Sensor Map</h3>
        <div style={{ height: "240px", borderRadius: T.radius, background: "#0d1117", border: `1px solid ${T.border}`, position: "relative", overflow: "hidden" }}>
          <svg width="100%" height="100%" viewBox="0 0 500 240">
            {Array.from({ length: 18 }, (_, i) => (<line key={`h${i}`} x1="0" y1={i * 14} x2="500" y2={i * 14} stroke={T.border} strokeWidth="0.5" />))}
            {Array.from({ length: 36 }, (_, i) => (<line key={`v${i}`} x1={i * 14} y1="0" x2={i * 14} y2="240" stroke={T.border} strokeWidth="0.5" />))}
            {[{ x: 250, y: 60, c: T.success, l: "Downtown" }, { x: 140, y: 120, c: T.success, l: "Harbour" }, { x: 380, y: 90, c: T.warning, l: "Industrial" }, { x: 80, y: 180, c: T.success, l: "Riverside" }, { x: 320, y: 170, c: T.error, l: "West End" }, { x: 440, y: 180, c: T.success, l: "Uptown" }].map((s, i) => (
              <g key={i}><circle cx={s.x} cy={s.y} r="16" fill={s.c} opacity="0.12" /><circle cx={s.x} cy={s.y} r="5" fill={s.c} /><text x={s.x} y={s.y - 12} textAnchor="middle" fill={T.textSecondary} fontSize="8" fontFamily={T.font}>{s.l}</text></g>
            ))}
          </svg>
        </div>
      </div>
      <div style={styles.card}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "12px" }}>
          <h3 style={styles.h3}>Active Alerts</h3><span style={{ fontSize: "12px", color: T.accent, cursor: "pointer" }} onClick={() => setPage("alerts")}>View all →</span>
        </div>
        <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
          {MOCK.alerts.filter(a => a.status === "active").map(a => (
            <div key={a.id} style={{ padding: "10px 12px", borderRadius: T.radius, background: a.severity === "critical" ? T.errorBg : T.warningBg, border: `1px solid ${a.severity === "critical" ? "rgba(238,0,0,0.12)" : "rgba(245,166,35,0.12)"}`, cursor: "pointer" }} onClick={() => setPage("alert-detail")}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                <div style={{ display: "flex", alignItems: "center", gap: "8px" }}><Icon name="alert" size={14} color={a.severity === "critical" ? T.error : T.warning} /><span style={{ fontWeight: 500, fontSize: "13px" }}>{a.id}</span></div>
                <span style={styles.badge(a.severity === "critical" ? "error" : "warning")}>{a.severity}</span>
              </div>
              <div style={{ fontSize: "12px", color: T.textSecondary, marginTop: "4px", marginLeft: "22px" }}>{a.type} in {a.zone} · {a.value}</div>
              <div style={{ fontSize: "11px", color: T.textMuted, marginTop: "2px", marginLeft: "22px" }}>{a.time}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
    <div style={{ ...styles.card, marginBottom: "48px" }}>
      <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Trend Overview (24h)</h3>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: "24px" }}>
        {[{ label: "Air Quality Index", data: MOCK.sparkData.aqi, color: T.warning, val: "42" }, { label: "Temperature (°C)", data: MOCK.sparkData.temp, color: T.accent, val: "18" }, { label: "Humidity (%)", data: MOCK.sparkData.humidity, color: T.accent, val: "62" }, { label: "Noise (dB)", data: MOCK.sparkData.noise, color: T.warning, val: "68" }].map((t, i) => (
          <div key={i}><div style={{ display: "flex", justifyContent: "space-between", marginBottom: "8px" }}><span style={{ fontSize: "12px", color: T.textSecondary }}>{t.label}</span><span style={{ fontSize: "13px", fontWeight: 600 }}>{t.val}</span></div><Sparkline data={t.data} color={t.color} width={240} height={40} /></div>
        ))}
      </div>
    </div>
  </div>
);

// ─── Page: Alerts List ───
const AlertsPage = ({ setPage }) => {
  const [filter, setFilter] = useState("all");
  const filtered = filter === "all" ? MOCK.alerts : MOCK.alerts.filter(a => a.status === filter);
  return (
    <div style={styles.container}>
      <div style={{ padding: "32px 0 24px", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
        <h1 style={styles.h1}>Alerts</h1>
        <div style={{ display: "flex", gap: "4px" }}>
          {["all", "active", "acknowledged", "resolved"].map(f => (<button key={f} style={{ ...styles.btn(filter === f ? "primary" : "default"), textTransform: "capitalize", fontSize: "12px" }} onClick={() => setFilter(f)}>{f}</button>))}
        </div>
      </div>
      <div style={styles.card}>
        <table style={styles.table}>
          <thead><tr><th style={styles.th}>ID</th><th style={styles.th}>Zone</th><th style={styles.th}>Type</th><th style={styles.th}>Value</th><th style={styles.th}>Rule</th><th style={styles.th}>Severity</th><th style={styles.th}>Status</th><th style={styles.th}>Time</th><th style={styles.th}></th></tr></thead>
          <tbody>
            {filtered.map(a => (
              <tr key={a.id} style={{ cursor: "pointer" }} onClick={() => setPage("alert-detail")}>
                <td style={{ ...styles.td, fontFamily: T.mono, fontSize: "12px" }}>{a.id}</td><td style={{ ...styles.td, fontWeight: 500 }}>{a.zone}</td><td style={styles.td}>{a.type}</td><td style={{ ...styles.td, fontFamily: T.mono }}>{a.value}</td><td style={{ ...styles.td, fontSize: "12px", color: T.textSecondary }}>{a.rule}</td>
                <td style={styles.td}><span style={styles.badge(a.severity === "critical" ? "error" : a.severity === "warning" ? "warning" : "info")}>{a.severity}</span></td>
                <td style={styles.td}><span style={styles.badge(a.status === "active" ? "error" : a.status === "acknowledged" ? "warning" : "success")}>{a.status}</span></td>
                <td style={{ ...styles.td, color: T.textMuted, fontSize: "12px" }}>{a.time}</td><td style={styles.td}><Icon name="chevron" size={14} color={T.textMuted} /></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
};

// ─── Page: Alert Detail ───
const AlertDetailPage = ({ setPage, role }) => {
  const alert = MOCK.alerts[0];
  return (
    <div style={styles.container}>
      <div style={{ padding: "32px 0 8px" }}><span style={{ fontSize: "13px", color: T.textSecondary, cursor: "pointer" }} onClick={() => setPage("alerts")}>← Back to alerts</span></div>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: "24px" }}>
        <div>
          <div style={{ display: "flex", alignItems: "center", gap: "12px" }}><h1 style={styles.h1}>{alert.id}</h1><span style={styles.badge("error")}>{alert.severity}</span><span style={styles.badge("error")}>{alert.status}</span></div>
          <p style={{ color: T.textSecondary, marginTop: "4px" }}>{alert.type} violation in {alert.zone}</p>
        </div>
        <div style={{ display: "flex", gap: "8px" }}>
          {role === "admin" && <button style={styles.btn()}><Icon name="edit" size={14} /> Edit</button>}
          <button style={styles.btn("primary")} onClick={() => setPage("alerts")}><Icon name="check" size={14} /> Acknowledge</button>
        </div>
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "16px", marginBottom: "24px" }}>
        <div style={styles.card}>
          <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Alert Details</h3>
          {[["Zone", alert.zone], ["Type", alert.type], ["Triggered Value", alert.value], ["Rule Violated", alert.rule], ["Triggered", alert.time], ["Sensor", "SN-051"], ["Status", alert.status]].map(([k, v], i) => (
            <div key={i} style={{ display: "flex", justifyContent: "space-between", padding: "8px 0", borderBottom: `1px solid ${T.border}` }}><span style={{ fontSize: "13px", color: T.textSecondary }}>{k}</span><span style={{ fontSize: "13px", fontWeight: 500 }}>{v}</span></div>
          ))}
        </div>
        <div style={styles.card}>
          <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Suggested Actions</h3>
          <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
            {["Issue public air quality advisory for West End zone", "Deploy mobile AQ monitoring unit to verify readings", "Notify public health department of threshold breach", "Check sensor SN-051 calibration status"].map((action, i) => (
              <div key={i} style={{ padding: "10px 14px", borderRadius: T.radius, background: T.bgHover, border: `1px solid ${T.border}`, fontSize: "13px", display: "flex", alignItems: "flex-start", gap: "8px" }}><span style={{ color: T.accent, marginTop: "1px" }}>→</span>{action}</div>
            ))}
          </div>
        </div>
      </div>
      <div style={{ ...styles.card, marginBottom: "48px" }}>
        <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Historical Trend — {alert.type}</h3>
        <Sparkline data={[65, 72, 78, 85, 92, 98, 105, 102, 108, 105]} color={T.error} width={1000} height={80} />
        <div style={{ display: "flex", justifyContent: "space-between", fontSize: "11px", color: T.textMuted, marginTop: "4px" }}><span>6h ago</span><span>Now</span></div>
      </div>
    </div>
  );
};

// ─── Page: Alert Rules ───
const AlertRulesPage = () => {
  const rules = [{ id: "R-001", name: "High AQI", condition: "AQI > 100", zone: "All Zones", status: "active" }, { id: "R-002", name: "Noise Violation", condition: "Noise > 80 dB", zone: "All Zones", status: "active" }, { id: "R-003", name: "Heat Warning", condition: "Temp > 30°C", zone: "All Zones", status: "active" }, { id: "R-004", name: "Low Humidity", condition: "Humidity < 20%", zone: "Industrial Park", status: "paused" }];
  const [showCreate, setShowCreate] = useState(false);
  return (
    <div style={styles.container}>
      <div style={{ padding: "32px 0 24px", display: "flex", justifyContent: "space-between", alignItems: "center" }}><h1 style={styles.h1}>Alert Rules</h1><button style={styles.btn("primary")} onClick={() => setShowCreate(!showCreate)}><Icon name="plus" size={14} /> Create Rule</button></div>
      {showCreate && (
        <div style={{ ...styles.card, marginBottom: "16px" }}>
          <h3 style={{ ...styles.h3, marginBottom: "16px" }}>New Alert Rule</h3>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "12px" }}>
            <div><label style={styles.label}>Rule Name</label><input style={styles.input} placeholder="e.g. High AQI Warning" /></div>
            <div><label style={styles.label}>Zone</label><select style={{ ...styles.input, cursor: "pointer" }}><option>All Zones</option>{MOCK.zones.map(z => <option key={z.id}>{z.name}</option>)}</select></div>
            <div><label style={styles.label}>Metric</label><select style={{ ...styles.input, cursor: "pointer" }}><option>Air Quality (AQI)</option><option>Temperature (°C)</option><option>Humidity (%)</option><option>Noise (dB)</option></select></div>
            <div><label style={styles.label}>Threshold</label><input style={styles.input} type="number" placeholder="100" /></div>
          </div>
          <div style={{ display: "flex", gap: "8px", marginTop: "16px", justifyContent: "flex-end" }}><button style={styles.btn()} onClick={() => setShowCreate(false)}>Cancel</button><button style={styles.btn("primary")}>Create Rule</button></div>
        </div>
      )}
      <div style={styles.card}>
        <table style={styles.table}>
          <thead><tr><th style={styles.th}>ID</th><th style={styles.th}>Name</th><th style={styles.th}>Condition</th><th style={styles.th}>Zone</th><th style={styles.th}>Status</th><th style={styles.th}></th></tr></thead>
          <tbody>
            {rules.map(r => (<tr key={r.id}><td style={{ ...styles.td, fontFamily: T.mono, fontSize: "12px" }}>{r.id}</td><td style={{ ...styles.td, fontWeight: 500 }}>{r.name}</td><td style={{ ...styles.td, fontFamily: T.mono, fontSize: "12px" }}>{r.condition}</td><td style={styles.td}>{r.zone}</td><td style={styles.td}><span style={styles.badge(r.status === "active" ? "success" : "default")}>{r.status}</span></td><td style={{ ...styles.td, display: "flex", gap: "8px" }}><Icon name="edit" size={14} color={T.textMuted} /><Icon name="trash" size={14} color={T.textMuted} /></td></tr>))}
          </tbody>
        </table>
      </div>
    </div>
  );
};

// ─── Page: Sensors ───
const SensorsPage = () => (
  <div style={styles.container}>
    <div style={{ padding: "32px 0 24px" }}><h1 style={styles.h1}>Sensors</h1><p style={{ color: T.textSecondary, marginTop: "4px" }}>IoT device status and management</p></div>
    <div style={styles.card}>
      <table style={styles.table}>
        <thead><tr><th style={styles.th}>Sensor ID</th><th style={styles.th}>Zone</th><th style={styles.th}>Type</th><th style={styles.th}>Status</th><th style={styles.th}>Last Ping</th><th style={styles.th}>Battery</th></tr></thead>
        <tbody>
          {MOCK.sensors.map(s => (
            <tr key={s.id}><td style={{ ...styles.td, fontFamily: T.mono, fontWeight: 500 }}>{s.id}</td><td style={styles.td}>{s.zone}</td><td style={styles.td}>{s.type}</td><td style={styles.td}><span style={styles.badge(s.status === "online" ? "success" : "error")}>{s.status}</span></td><td style={{ ...styles.td, color: T.textSecondary, fontSize: "12px" }}>{s.lastPing}</td>
              <td style={styles.td}><div style={{ display: "flex", alignItems: "center", gap: "8px" }}><div style={{ width: "48px", height: "4px", borderRadius: "2px", background: T.border, overflow: "hidden" }}><div style={{ width: s.battery, height: "100%", borderRadius: "2px", background: parseInt(s.battery) > 50 ? T.success : parseInt(s.battery) > 20 ? T.warning : T.error }} /></div><span style={{ fontSize: "12px", color: T.textSecondary }}>{s.battery}</span></div></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
);

// ─── Page: Rankings ───
const RankingsPage = () => {
  const [sortBy, setSortBy] = useState("aqi");
  const [search, setSearch] = useState("");
  const sorted = [...MOCK.cities].filter(c => c.name.toLowerCase().includes(search.toLowerCase())).sort((a, b) => a[sortBy] - b[sortBy]);
  return (
    <div style={styles.container}>
      <div style={{ padding: "32px 0 24px" }}><h1 style={styles.h1}>City Rankings</h1><p style={{ color: T.textSecondary, marginTop: "4px" }}>Environmental quality rankings across Canadian cities</p></div>
      <div style={{ display: "flex", gap: "12px", marginBottom: "16px" }}>
        <div style={{ position: "relative", flex: 1 }}><Icon name="search" size={14} color={T.textMuted} style={{ position: "absolute", left: "12px", top: "50%", transform: "translateY(-50%)" }} /><input style={{ ...styles.input, paddingLeft: "36px" }} placeholder="Search cities..." value={search} onChange={e => setSearch(e.target.value)} /></div>
        <div style={{ display: "flex", gap: "4px" }}>{[{ key: "aqi", label: "AQI" }, { key: "temp", label: "Temp" }, { key: "noise", label: "Noise" }, { key: "humidity", label: "Humidity" }].map(f => (<button key={f.key} style={{ ...styles.btn(sortBy === f.key ? "primary" : "default"), fontSize: "12px" }} onClick={() => setSortBy(f.key)}>{f.label}</button>))}</div>
      </div>
      <div style={styles.card}>
        <table style={styles.table}>
          <thead><tr><th style={styles.th}>#</th><th style={styles.th}>City</th><th style={{ ...styles.th, cursor: "pointer" }} onClick={() => setSortBy("aqi")}>AQI {sortBy === "aqi" && "↑"}</th><th style={{ ...styles.th, cursor: "pointer" }} onClick={() => setSortBy("temp")}>Temp {sortBy === "temp" && "↑"}</th><th style={{ ...styles.th, cursor: "pointer" }} onClick={() => setSortBy("noise")}>Noise {sortBy === "noise" && "↑"}</th><th style={{ ...styles.th, cursor: "pointer" }} onClick={() => setSortBy("humidity")}>Humidity {sortBy === "humidity" && "↑"}</th></tr></thead>
          <tbody>
            {sorted.map((c, i) => (<tr key={c.name}><td style={{ ...styles.td, fontWeight: 600, color: i < 3 ? T.accent : T.textSecondary }}>{i + 1}</td><td style={{ ...styles.td, fontWeight: 500 }}>{c.name}</td><td style={{ ...styles.td, fontFamily: T.mono }}><span style={{ color: c.aqi < 35 ? T.success : c.aqi < 55 ? T.warning : T.error }}>{c.aqi}</span></td><td style={{ ...styles.td, fontFamily: T.mono }}>{c.temp}°C</td><td style={{ ...styles.td, fontFamily: T.mono }}>{c.noise} dB</td><td style={{ ...styles.td, fontFamily: T.mono }}>{c.humidity}%</td></tr>))}
          </tbody>
        </table>
      </div>
    </div>
  );
};

// ─── Page: Accounts ───
const AccountsPage = () => {
  const [showCreate, setShowCreate] = useState(false);
  return (
    <div style={styles.container}>
      <div style={{ padding: "32px 0 24px", display: "flex", justifyContent: "space-between", alignItems: "center" }}><h1 style={styles.h1}>Accounts</h1><button style={styles.btn("primary")} onClick={() => setShowCreate(!showCreate)}><Icon name="plus" size={14} /> Create Account</button></div>
      {showCreate && (
        <div style={{ ...styles.card, marginBottom: "16px" }}>
          <h3 style={{ ...styles.h3, marginBottom: "16px" }}>New Account</h3>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: "12px" }}>
            <div><label style={styles.label}>Email</label><input style={styles.input} placeholder="user@scemas.ca" /></div>
            <div><label style={styles.label}>Password</label><input style={styles.input} type="password" placeholder="••••••••" /></div>
            <div><label style={styles.label}>Role</label><select style={{ ...styles.input, cursor: "pointer" }}><option>Operator</option><option>Administrator</option></select></div>
          </div>
          <div style={{ display: "flex", gap: "8px", marginTop: "16px", justifyContent: "flex-end" }}><button style={styles.btn()} onClick={() => setShowCreate(false)}>Cancel</button><button style={styles.btn("primary")}>Create</button></div>
        </div>
      )}
      <div style={styles.card}>
        <table style={styles.table}>
          <thead><tr><th style={styles.th}>Email</th><th style={styles.th}>Role</th><th style={styles.th}>Created</th><th style={styles.th}>Last Login</th><th style={styles.th}></th></tr></thead>
          <tbody>
            {MOCK.accounts.map(a => (<tr key={a.email}><td style={{ ...styles.td, fontWeight: 500 }}>{a.email}</td><td style={styles.td}><span style={styles.badge(a.role === "Administrator" ? "info" : "default")}>{a.role}</span></td><td style={{ ...styles.td, color: T.textSecondary, fontSize: "12px" }}>{a.created}</td><td style={{ ...styles.td, color: T.textSecondary, fontSize: "12px" }}>{a.lastLogin}</td><td style={{ ...styles.td, display: "flex", gap: "8px" }}><Icon name="edit" size={14} color={T.textMuted} /><Icon name="trash" size={14} color={T.textMuted} /></td></tr>))}
          </tbody>
        </table>
      </div>
    </div>
  );
};

// ─── Page: Edit Account ───
