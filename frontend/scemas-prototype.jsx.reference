    <div style={{ maxWidth: "600px" }}>
      <div style={styles.card}>
        <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Profile</h3>
        <div style={{ display: "flex", flexDirection: "column", gap: "12px" }}>
          <div><label style={styles.label}>Email</label><input style={styles.input} value="operator1@scemas.ca" readOnly /></div>
          <div><label style={styles.label}>Role</label><input style={styles.input} value="Operator" readOnly /></div>
        </div>
      </div>
      <div style={{ ...styles.card, marginTop: "16px" }}>
