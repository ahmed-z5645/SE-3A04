          <div><label style={styles.label}>Current Password</label><input style={styles.input} type="password" placeholder="••••••••" /></div>
          <div><label style={styles.label}>New Password</label><input style={styles.input} type="password" placeholder="Minimum 8 characters" /></div>
          <div><label style={styles.label}>Confirm New Password</label><input style={styles.input} type="password" placeholder="Repeat new password" /></div>
        </div>
        <div style={{ display: "flex", justifyContent: "flex-end", marginTop: "16px" }}><button style={styles.btn("primary")}>Update Password</button></div>
      </div>
      <div style={{ ...styles.card, marginTop: "16px", marginBottom: "48px" }}>
        <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Preferences</h3>
        <div style={{ display: "flex", flexDirection: "column", gap: "12px" }}>
