);

// ─── Page: Audit Log ───
const AuditLogPage = () => (
  <div style={styles.container}>
    <div style={{ padding: "32px 0 24px" }}><h1 style={styles.h1}>Audit Log</h1><p style={{ color: T.textSecondary, marginTop: "4px" }}>System activity and change history</p></div>
    <div style={styles.card}>
      <table style={styles.table}>
        <thead><tr><th style={styles.th}>Time</th><th style={styles.th}>User</th><th style={styles.th}>Action</th><th style={styles.th}>Detail</th></tr></thead>
        <tbody>
          {MOCK.auditLogs.map((l, i) => (<tr key={i}><td style={{ ...styles.td, fontFamily: T.mono, fontSize: "12px", color: T.textSecondary, whiteSpace: "nowrap" }}>{l.time}</td><td style={{ ...styles.td, fontSize: "12px" }}>{l.user}</td><td style={{ ...styles.td, fontWeight: 500 }}>{l.action}</td><td style={{ ...styles.td, color: T.textSecondary }}>{l.detail}</td></tr>))}
        </tbody>
      </table>
    </div>
  </div>
);

// ─── Page: API Docs ───
const ApiDocsPage = () => (
  <div style={styles.container}>
    <div style={{ padding: "32px 0 24px" }}><h1 style={styles.h1}>Public API</h1><p style={{ color: T.textSecondary, marginTop: "4px" }}>REST API documentation for third-party integrations</p></div>
    <div style={{ ...styles.card, marginBottom: "16px" }}>
      <h3 style={{ ...styles.h3, marginBottom: "12px" }}>Base URL</h3>
      <div style={{ padding: "10px 14px", borderRadius: T.radius, background: T.bgHover, fontFamily: T.mono, fontSize: "13px", border: `1px solid ${T.border}` }}>https://api.scemas.ca/v1</div>
      <div style={{ marginTop: "12px", fontSize: "13px", color: T.textSecondary }}>All requests require an API key via the <code style={{ fontFamily: T.mono, background: T.bgHover, padding: "1px 4px", borderRadius: "3px" }}>X-API-Key</code> header. Rate limited to 100 requests per minute.</div>
    </div>
    <div style={{ ...styles.card, marginBottom: "16px" }}>
      <h3 style={{ ...styles.h3, marginBottom: "16px" }}>Endpoints</h3>
      <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
        {MOCK.apiEndpoints.map((ep, i) => (
          <div key={i} style={{ padding: "12px 16px", borderRadius: T.radius, border: `1px solid ${T.border}`, display: "flex", alignItems: "center", gap: "12px" }}>
            <span style={{ padding: "2px 8px", borderRadius: "4px", background: T.successBg, color: T.success, fontFamily: T.mono, fontSize: "11px", fontWeight: 600 }}>{ep.method}</span>
            <span style={{ fontFamily: T.mono, fontSize: "13px", fontWeight: 500 }}>{ep.path}</span>
            <span style={{ fontSize: "13px", color: T.textSecondary, marginLeft: "auto" }}>{ep.desc}</span>
          </div>
        ))}
      </div>
    </div>
    <div style={{ ...styles.card, marginBottom: "48px" }}>
      <h3 style={{ ...styles.h3, marginBottom: "12px" }}>Example Response</h3>
      <pre style={{ padding: "16px", borderRadius: T.radius, background: T.bgHover, fontFamily: T.mono, fontSize: "12px", lineHeight: "1.6", border: `1px solid ${T.border}`, overflow: "auto", color: T.textSecondary, margin: 0 }}>
{`{
  "zone_id": "z1",
  "zone_name": "Downtown Core",
  "timestamp": "2026-04-03T14:30:00Z",
  "metrics": {
    "aqi": 42,
    "temperature_c": 18,
    "humidity_pct": 62,
    "noise_db": 68
  },
  "status": "good"
}`}
      </pre>
    </div>
  </div>
);

// ─── Main App ───
export default function App() {
  const [page, setPage] = useState("login");
  const [role, setRole] = useState(null);

  const handleLogin = (r) => { setRole(r); setPage(r === "public" ? "public" : "dashboard"); };
  const handleLogout = () => { setPage("login"); setRole(null); };

  if (page === "login") return <LoginPage onLogin={handleLogin} />;
  if (page === "create-account") return <CreateAccountPage setPage={setPage} />;

  const renderPage = () => {
    switch (page) {
      case "public": return <PublicPage />;
      case "dashboard": return <DashboardPage role={role} setPage={setPage} />;
      case "alerts": return <AlertsPage setPage={setPage} />;
      case "alert-detail": return <AlertDetailPage setPage={setPage} role={role} />;
      case "alert-rules": return <AlertRulesPage />;
      case "sensors": return <SensorsPage />;
      case "rankings": return <RankingsPage />;
      case "accounts": return <AccountsPage />;
      case "account-edit": return <EditAccountPage />;
      case "audit": return <AuditLogPage />;
      case "api-docs": return <ApiDocsPage />;
      default: return <PublicPage />;
    }
  };

  return (
    <div style={styles.page}>
      <Navbar page={page} setPage={setPage} role={role} onLogout={handleLogout} />
      {renderPage()}
    </div>
  );
}
