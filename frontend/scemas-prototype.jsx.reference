import { useState, useEffect, useRef } from "react";

// ─── Design Tokens (Vercel-inspired) ───
const T = {
  bg: "#000000",
  bgCard: "#0a0a0a",
  bgHover: "#111111",
  bgInput: "#0a0a0a",
  border: "#1a1a1a",
  borderHover: "#333333",
  text: "#ededed",
  textSecondary: "#888888",
  textMuted: "#666666",
  accent: "#0070f3",
  accentHover: "#0060df",
  success: "#00c853",
  warning: "#f5a623",
  error: "#ee0000",
  errorBg: "rgba(238,0,0,0.08)",
  successBg: "rgba(0,200,83,0.08)",
  warningBg: "rgba(245,166,35,0.08)",
  accentBg: "rgba(0,112,243,0.08)",
  radius: "8px",
  radiusLg: "12px",
  font: "'Geist', -apple-system, sans-serif",
  mono: "'Geist Mono', 'SF Mono', monospace",
  shadow: "0 2px 8px rgba(0,0,0,0.5)",
  transition: "all 0.15s ease",
};

// ─── Shared Styles ───
const styles = {
  page: {
    minHeight: "100vh",
    background: T.bg,
    color: T.text,
    fontFamily: T.font,
    fontSize: "14px",
    lineHeight: "1.6",
  },
  container: {
    maxWidth: "1200px",
    margin: "0 auto",
    padding: "0 24px",
  },
  nav: {
    display: "flex",
    alignItems: "center",
    justifyContent: "space-between",
    padding: "16px 24px",
    borderBottom: `1px solid ${T.border}`,
    position: "sticky",
    top: 0,
    background: "rgba(0,0,0,0.8)",
    backdropFilter: "blur(12px)",
    zIndex: 100,
  },
  navLeft: {
    display: "flex",
    alignItems: "center",
    gap: "24px",
  },
  logo: {
    fontSize: "16px",
    fontWeight: 700,
    letterSpacing: "-0.02em",
    display: "flex",
    alignItems: "center",
    gap: "8px",
    cursor: "pointer",
  },
  navLink: (active) => ({
    fontSize: "13px",
    color: active ? T.text : T.textSecondary,
    cursor: "pointer",
    transition: T.transition,
    padding: "4px 0",
    borderBottom: active ? `1px solid ${T.text}` : "1px solid transparent",
  }),
  btn: (variant = "default") => ({
    padding: variant === "sm" ? "6px 12px" : "8px 16px",
    borderRadius: T.radius,
    border: variant === "primary" ? "none" : `1px solid ${T.border}`,
    background: variant === "primary" ? T.accent : "transparent",
    color: variant === "primary" ? "#fff" : T.text,
    fontSize: "13px",
    fontWeight: 500,
    cursor: "pointer",
    transition: T.transition,
    fontFamily: T.font,
    display: "inline-flex",
    alignItems: "center",
    gap: "6px",
  }),
  input: {
    padding: "8px 12px",
    borderRadius: T.radius,
    border: `1px solid ${T.border}`,
    background: T.bgInput,
    color: T.text,
    fontSize: "14px",
    fontFamily: T.font,
    outline: "none",
    width: "100%",
    transition: T.transition,
  },
  card: {
    background: T.bgCard,
    border: `1px solid ${T.border}`,
    borderRadius: T.radiusLg,
    padding: "20px",
    transition: T.transition,
  },
  badge: (type = "default") => {
    const colors = {
      default: { bg: T.border, color: T.textSecondary },
      success: { bg: T.successBg, color: T.success },
      warning: { bg: T.warningBg, color: T.warning },
      error: { bg: T.errorBg, color: T.error },
      info: { bg: T.accentBg, color: T.accent },
    };
    const c = colors[type] || colors.default;
    return {
      padding: "2px 8px",
      borderRadius: "9999px",
      fontSize: "11px",
      fontWeight: 500,
      background: c.bg,
      color: c.color,
      display: "inline-flex",
      alignItems: "center",
      gap: "4px",
    };
  },
  table: {
    width: "100%",
    borderCollapse: "collapse",
  },
  th: {
    padding: "10px 16px",
    textAlign: "left",
    fontSize: "12px",
    fontWeight: 500,
    color: T.textMuted,
    borderBottom: `1px solid ${T.border}`,
    textTransform: "uppercase",
    letterSpacing: "0.05em",
  },
  td: {
    padding: "12px 16px",
    borderBottom: `1px solid ${T.border}`,
    fontSize: "13px",
  },
  h1: {
    fontSize: "32px",
    fontWeight: 700,
    letterSpacing: "-0.04em",
    lineHeight: 1.2,
  },
  h2: {
    fontSize: "20px",
    fontWeight: 600,
    letterSpacing: "-0.02em",
  },
  h3: {
    fontSize: "16px",
    fontWeight: 600,
    letterSpacing: "-0.01em",
  },
  label: {
    fontSize: "13px",
    fontWeight: 500,
    color: T.textSecondary,
    marginBottom: "6px",
    display: "block",
  },
  separator: {
    height: "1px",
    background: T.border,
    margin: "24px 0",
  },
};

